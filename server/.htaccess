# server/.htaccess — Sperrt den File-Cache-Ordner der fetch.php.
# Gilt im Repo für server/cache/ und wird vom Workflow nach dist/api/ kopiert.
# Server-seitiger Cache darf NIEMALS direkt ausgeliefert werden (enthält
# fremde Feed-Inhalte + könnte als offener Speicher missbraucht werden).

# Apache 2.4+ — alles unter diesem Ordner blockieren (auch .cache-Dateien).
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>

# Apache 2.2 (Fallback, falls noch aktiv).
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>
