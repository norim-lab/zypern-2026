# =============================================================================
# .htaccess für „Zypern 2026" (Apache, IONOS/Hestia).
#
# Landet über Vite automatisch in dist/ und wird mit ausgeliefert.
# Aufgaben:
#   1. SPA-Routing: alle Pfade auf index.html, AUSSER existierende Dateien/
#      Ordner und AUSSER /api/ (PHP-Proxy muss erreichbar bleiben).
#   2. Korrekte MIME-Types (PWA-Installation, Fonts, Manifest).
#   3. Caching: index.html + sw.js NIEMALS cachen (sonst erscheint der
#      PWA-Update-Banner nie). Gehashte Assets (JS/CSS/Fonts) lange cachen.
# =============================================================================

# --- (1) SPA-Routing --------------------------------------------------------
# React Router routed client-seitig. Deep-Links / Reload auf /entdecken/einkaufen
# würden ohne Rewrite 404 auslösen. Existierende Dateien + /api/ bleiben unangetastet.
<IfModule mod_rewrite.c>
    RewriteEngine On

    # /api/ nicht umschreiben — sonst wäre der PHP-Proxy nicht erreichbar.
    RewriteRule ^api/ - [L]

    # Existierende Dateien/Ordner direkt ausliefern (JS/CSS/Bilder/Fonts).
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Alles andere → index.html (SPA-Fallback).
    RewriteRule ^ index.html [L]
</IfModule>

# --- (2) MIME-Types ---------------------------------------------------------
# Wichtig für PWA-Installation (Manifest) und moderne Font-/Bildformate.
<IfModule mod_mime.c>
    AddType application/manifest+json           .webmanifest
    AddType application/javascript              .mjs
    AddType font/woff2                          .woff2
    AddType image/svg+xml                       .svg
    AddType application/json                    .json
</IfModule>

# --- (3) Caching ------------------------------------------------------------
# Strategie: gehashte Assets dürfen „unendlich" cachen (Dateiname ändert sich
# bei jedem Build). index.html + sw.js müssen IMMER frisch geholt werden,
# weil sie die neuen Hashes referenzieren — sonst bleibt der Nutzer auf einer
# alten Version und der Update-Banner erscheint nie.

# (3a) index.html + sw.js + manifest: NIEMALS cachen.
<FilesMatch "^(index\.html|sw\.js|manifest\.webmanifest)$">
    <IfModule mod_headers.c>
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header setPragma "no-cache"
    </IfModule>
</FilesMatch>

# (3b) Gehashte Vite-Assets (lange cachen — Dateiname ändert sich je Build).
<FilesMatch "\.(js|mjs|css|woff2|png|jpg|jpeg|svg|ico)$">
    <IfModule mod_headers.c>
        Header set Cache-Control "public, max-age=31536000, immutable"
    </IfModule>
</FilesMatch>

# (3c) /api/fetch.php eigene Cache-Header? — NEIN. Die PHP-Datei setzt selbst
#      Cache-Control: public, max-age=1800 (siehe fetch.php). Hier nicht
#      überschreiben.

# --- (4) gzip-Kompression (kleinere Assets, schnellerer Erst-Lade) -----------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/plain
        application/javascript application/json image/svg+xml
</IfModule>

# --- (5) Security-Header (Best-Effort auf Shared-Hosting) --------------------
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# --- (6) UTF-8 Default ------------------------------------------------------
AddDefaultCharset UTF-8
