# =============================================================================
# .env.example — Vorlage für optionale API-Keys / Konfiguration (v0.4).
# Kopieren nach .env.local und Werte eintragen. OHNE diese Variablen läuft die
# App vollständig (Default-Provider). Keys werden NIE committet (.gitignore).
# =============================================================================

# Personenbezogene Werte im UI ausblenden (für Screenshots/Demos).
# VITE_PRIVATE_MODE=true

# --- Optional: Google Places API (Restaurant-Live-Daten) ---
# Mit Key: Rating, Bewertungen, Preisniveau, „jetzt geöffnet" automatisch.
# Ohne Key: Default-Lokal-Karten (Maps-Buttons + Familien-Sterne + Foto-Upload).
# VITE_PLACES_API_KEY=dein_google_places_key

# --- Optional: LibreTranslate-/DeepL-kompatible API (Übersetzung) ---
# Mit URL+Key: app-interne Angebotstexte werden automatisch übersetzt.
# Ohne: Originaltext + „Auf Deutsch öffnen"-Link (Google-Translate-Wrapper).
# VITE_TRANSLATE_API_URL=https://libretranslate.com/translate
# VITE_TRANSLATE_API_KEY=dein_translate_key
